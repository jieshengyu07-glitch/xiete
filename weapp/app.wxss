page {
  min-height: 100%;
  background: #f3f7ff;
  color: #1f2d3d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: linear-gradient(180deg, #eef6ff 0%, #f7f9fc 320rpx, #f7f9fc 100%);
}

.card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.06);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(38, 84, 153, 0.08);
}

.card-title {
  margin-bottom: 24rpx;
  color: #152338;
  font-size: 32rpx;
  font-weight: 700;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef2f8;
}

.row:last-child {
  border-bottom: none;
}

.label {
  flex-shrink: 0;
  color: #667085;
  font-size: 26rpx;
}

.value {
  color: #25324a;
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
  word-break: break-all;
}

.btn {
  display: block;
  width: 100%;
  height: 88rpx;
  margin: 22rpx 0 0;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1677ff 0%, #2f8cff 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  box-shadow: 0 12rpx 28rpx rgba(22, 119, 255, 0.22);
}

.btn:active {
  opacity: 0.86;
}

.secondary {
  background: #eaf2ff;
  color: #1677ff;
  box-shadow: none;
}

.empty {
  padding: 34rpx 0;
  color: #98a2b3;
  font-size: 26rpx;
  text-align: center;
}

.loading {
  padding: 70rpx 0;
  color: #98a2b3;
  font-size: 28rpx;
  text-align: center;
}

.tips {
  margin-top: 16rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.7;
}
