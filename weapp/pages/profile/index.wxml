<view class="profile-page">
  <view class="profile-card">
    <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar">{{avatarLetter}}</view>
    <view class="profile-main">
      <view class="profile-title">{{displayName}}</view>
      <view class="profile-desc">{{profileDesc}}</view>
      <view class="bind-pill {{bindStatusClass}}">{{bindStatusText}}</view>
    </view>
  </view>

  <view class="status-card">
    <view class="section-title">成绩状态</view>
    <view class="status-row">
      <text class="status-label">成绩同步</text>
      <text class="status-value {{gradeStatusClass}}">{{gradeQueryStatusText}}</text>
    </view>
    <view class="status-row">
      <text class="status-label">最近同步</text>
      <text class="status-time">{{lastCheckAtText}}</text>
    </view>
  </view>

  <view class="action-card">
    <button class="action-btn primary" loading="{{loadingStatus}}" disabled="{{loadingStatus}}" bindtap="refreshStatus">刷新状态</button>
    <button class="action-btn secondary-action" bindtap="manageJwxt">{{bindButtonText}}</button>
  </view>
</view>
