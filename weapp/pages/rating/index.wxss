.rating-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #eef6ff 0%, #f7f9fc 300rpx, #f7f9fc 100%);
}

.page-head {
  margin-bottom: 22rpx;
}

.page-title {
  color: #152338;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 92rpx;
  margin-bottom: 24rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.08);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.search-icon {
  color: #98a2b3;
  font-size: 34rpx;
  font-weight: 700;
}

.search-input {
  flex: 1;
  color: #22304a;
  font-size: 28rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.entry-card {
  min-height: 174rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.08);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.entry-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #eaf2ff 0%, #f3f8ff 100%);
  color: #1677ff;
  font-size: 26rpx;
  font-weight: 850;
  line-height: 60rpx;
  text-align: center;
}

.entry-title {
  color: #17233c;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.3;
}

.entry-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.section {
  margin-bottom: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #152338;
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.25;
}

.section-subtitle {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 23rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.review-card {
  box-sizing: border-box;
  padding: 26rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.08);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(38, 84, 153, 0.08);
}

.review-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.review-rank {
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #b76a00;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 44rpx;
}

.review-score {
  flex-shrink: 0;
  color: #ff8a00;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1;
}

.review-score text {
  margin-left: 4rpx;
  font-size: 21rpx;
  font-weight: 750;
}

.review-name {
  color: #17233c;
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.35;
}

.review-meta {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 12rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.quote {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.6;
}
