.rating-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f7f9fc;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 88rpx;
  margin-bottom: 24rpx;
  padding: 0 26rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.08);
}

.search-icon {
  color: #8a94a6;
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  color: #22304a;
  font-size: 28rpx;
}

.section {
  margin-bottom: 28rpx;
}

.scroll-section {
  margin-right: -24rpx;
}

.section-title {
  margin-bottom: 18rpx;
  color: #152338;
  font-size: 32rpx;
  font-weight: 750;
}

.category-grid {
  display: flex;
  gap: 18rpx;
}

.category-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  width: calc((100% - 18rpx) / 2);
  min-height: 142rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.06);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.category-icon {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  border-radius: 17rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 54rpx;
  text-align: center;
}

.category-main {
  flex: 1;
  min-width: 0;
}

.category-title {
  color: #22304a;
  font-size: 28rpx;
  font-weight: 750;
}

.category-desc {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
  line-height: 1.45;
}

.review-scroll {
  width: 100%;
  white-space: nowrap;
}

.review-scroll-inner {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 24rpx;
}

.review-card {
  display: inline-block;
  width: 560rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.08);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(38, 84, 153, 0.1);
  white-space: normal;
}

.review-rank {
  display: inline-block;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff2d8;
  color: #b76a00;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 48rpx;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.review-name {
  flex: 1;
  min-width: 0;
  color: #22304a;
  font-size: 30rpx;
  font-weight: 780;
}

.review-score {
  flex-shrink: 0;
  color: #ff8a00;
  font-size: 38rpx;
  font-weight: 850;
}

.review-score text {
  margin-left: 3rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.review-meta {
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 23rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 650;
}

.quote {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}
