.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f7f9fc;
}

.hero-card,
.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.hero-card {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #1677ff 0%, #3aa0ff 100%);
  color: #ffffff;
}

.course-name {
  font-size: 40rpx;
  font-weight: 850;
}

.course-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.score {
  flex-shrink: 0;
  font-size: 44rpx;
  font-weight: 850;
}

.score text {
  margin-left: 3rpx;
  font-size: 22rpx;
}

.card-title {
  margin-bottom: 20rpx;
  color: #152338;
  font-size: 30rpx;
  font-weight: 800;
}

.dim-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dim-item {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
}

.dim-label,
.paper-meta,
.paper-tags {
  color: #98a2b3;
  font-size: 23rpx;
}

.dim-value {
  margin-top: 8rpx;
  color: #ff8a00;
  font-size: 34rpx;
  font-weight: 850;
}

.guide-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f8;
  color: #4b5870;
  font-size: 25rpx;
  line-height: 1.55;
}

.comment {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f8;
}

.guide-row:last-child,
.comment:last-child {
  border-bottom: none;
}

.comment-text {
  flex: 1;
  min-width: 0;
  color: #4b5870;
  font-size: 25rpx;
  line-height: 1.55;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f6fc;
  color: #667085;
  font-size: 22rpx;
}

.like-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 106rpx;
  height: 52rpx;
  box-sizing: border-box;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f2f6fc;
  color: #667085;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 52rpx;
}

.like-btn.liked {
  background: #fff2d8;
  color: #d98000;
}

.like-count {
  font-weight: 850;
}

.safe-tip {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff7e8;
  color: #9a6700;
  font-size: 23rpx;
  line-height: 1.6;
}

.paper-card {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
}

.paper-title {
  color: #22304a;
  font-size: 27rpx;
  font-weight: 800;
}

.paper-meta,
.paper-tags,
.paper-note {
  margin-top: 8rpx;
}

.paper-note {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.resource-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.resource-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 700;
}

.review-form-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.review-field {
  width: calc((100% - 14rpx) / 2);
  box-sizing: border-box;
}

.form-label {
  margin-bottom: 8rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 700;
}

.mini-input,
.tag-input,
.review-textarea {
  box-sizing: border-box;
  width: 100%;
  border-radius: 16rpx;
  background: #f6f9ff;
  color: #22304a;
  font-size: 25rpx;
}

.mini-input {
  height: 72rpx;
  padding: 0 18rpx;
}

.tag-input {
  height: 76rpx;
  margin-top: 18rpx;
  padding: 0 18rpx;
}

.review-textarea {
  min-height: 160rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.primary-btn {
  margin-top: 20rpx;
  border-radius: 18rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
}

.easter-egg {
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #98a2b3;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.egg-title {
  color: #667085;
  font-size: 24rpx;
  font-weight: 750;
}

.egg-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.55;
}
