.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #eef6ff 0%, #f7f9fc 280rpx, #f7f9fc 100%);
}

.form-card {
  max-width: 720rpx;
  box-sizing: border-box;
  margin: 0 auto;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.field {
  margin-bottom: 26rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #22304a;
  font-size: 26rpx;
  font-weight: 750;
}

.input,
.picker {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.08);
  border-radius: 18rpx;
  background: #f6f9ff;
  color: #22304a;
  font-size: 26rpx;
  line-height: 88rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker.placeholder {
  color: #98a2b3;
}

.picker-arrow {
  color: #98a2b3;
  font-size: 22rpx;
}

.primary-btn {
  height: 90rpx;
  margin-top: 14rpx;
  border-radius: 18rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 750;
  line-height: 90rpx;
  box-shadow: 0 12rpx 26rpx rgba(22, 119, 255, 0.18);
}
