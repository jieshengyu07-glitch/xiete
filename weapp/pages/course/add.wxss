.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f7f9fc;
}

.form-card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.field {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #22304a;
  font-size: 26rpx;
  font-weight: 750;
}

.input,
.picker,
.textarea {
  box-sizing: border-box;
  width: 100%;
  border-radius: 18rpx;
  background: #f6f9ff;
  color: #22304a;
  font-size: 26rpx;
}

.input,
.picker {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

.textarea {
  min-height: 150rpx;
  padding: 20rpx 22rpx;
}

.primary-btn {
  height: 86rpx;
  margin-top: 10rpx;
  border-radius: 18rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 750;
  line-height: 86rpx;
}
