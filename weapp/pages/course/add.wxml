<view class="page">
  <view class="form-card">
    <view class="field">
      <view class="label">课程名称</view>
      <input class="input" placeholder="必填" value="{{name}}" data-key="name" bindinput="input" />
    </view>
    <view class="field">
      <view class="label">所属学院</view>
      <input class="input" placeholder="必填" value="{{college}}" data-key="college" bindinput="input" />
    </view>
    <view class="field">
      <view class="label">所属专业</view>
      <input class="input" placeholder="必填" value="{{major}}" data-key="major" bindinput="input" />
    </view>
    <view class="field">
      <view class="label">课程类型</view>
      <picker range="{{courseTypes}}" value="{{typeIndex}}" bindchange="changeType">
        <view class="picker">{{courseTypes[typeIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">开课学期</view>
      <picker range="{{terms}}" value="{{termIndex}}" bindchange="changeTerm">
        <view class="picker">{{terms[termIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">备注</view>
      <textarea class="textarea" placeholder="可选，补充课程别名、老师或上课信息" value="{{remark}}" data-key="remark" bindinput="input" />
    </view>
    <button class="primary-btn" loading="{{submitting}}" bindtap="submit">提交课程</button>
  </view>
</view>
