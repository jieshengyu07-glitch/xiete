<view class="page">
  <view class="form-card">
    <view class="field">
      <view class="label">课程名称</view>
      <input class="input" placeholder="必填" value="{{name}}" data-key="name" bindinput="input" />
    </view>
    <view class="field">
      <view class="label">所属学院</view>
      <picker range="{{colleges}}" value="{{collegeIndex}}" bindchange="changeCollege">
        <view class="picker {{college ? '' : 'placeholder'}}">
          <text>{{college || '请选择所属学院'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="field">
      <view class="label">所属专业</view>
      <picker range="{{majors}}" value="{{majorIndex}}" bindchange="changeMajor" disabled="{{!majors.length}}">
        <view class="picker {{major ? '' : 'placeholder'}}">
          <text>{{major || '请选择所属专业'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="field">
      <view class="label">课程类型</view>
      <picker range="{{courseTypes}}" value="{{typeIndex}}" bindchange="changeType">
        <view class="picker">
          <text>{{courseTypes[typeIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="field">
      <view class="label">开课学期</view>
      <picker range="{{terms}}" value="{{termIndex}}" bindchange="changeTerm">
        <view class="picker">
          <text>{{terms[termIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <button class="primary-btn" loading="{{submitting}}" bindtap="submit">提交课程</button>
  </view>
</view>
