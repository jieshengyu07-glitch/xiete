.rank-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f7f9fc;
}

.board-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.board-head {
  margin-bottom: 8rpx;
}

.board-title {
  color: #152338;
  font-size: 32rpx;
  font-weight: 800;
}

.board-subtitle {
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 23rpx;
}

.rank-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef2f8;
}

.rank-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.rank-row.first {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #ffe3ad;
  border-radius: 22rpx;
  background: #fffaf0;
}

.rank-index {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 58rpx;
  text-align: center;
}

.rank-row.first .rank-index {
  background: #ffb84d;
  color: #ffffff;
}

.rank-main {
  flex: 1;
  min-width: 0;
}

.rank-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rank-name {
  color: #22304a;
  font-size: 30rpx;
  font-weight: 800;
}

.rank-canteen {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #d98000;
  font-size: 21rpx;
  font-weight: 700;
}

.rank-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f6fc;
  color: #667085;
  font-size: 22rpx;
  font-weight: 650;
}

.rank-quote {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  color: #4b5870;
  font-size: 24rpx;
  line-height: 1.55;
}

.rank-row.first .rank-quote {
  background: #ffffff;
}
