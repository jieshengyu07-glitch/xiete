<view class="login-page">
  <view class="login-card">
    <view class="login-icon">科</view>
    <view class="login-title">登录科大助手</view>
    <view class="login-desc">使用微信登录后，可发布课程评价、美食评价、点赞、收藏和上传资料。</view>

    <button class="primary-btn" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="login">微信一键登录</button>

    <view wx:if="{{error}}" class="error-text">{{error}}</view>

    <view class="secondary-note">
      教务账号仅用于课表、成绩和教务状态同步，登录后可在设置中绑定。
    </view>
    <view class="settings-link" bindtap="goSettings">前往设置绑定教务</view>
  </view>
</view>
