<view class="container">
  <view class="status-card">
    <view>
      <view class="status-label">教务状态</view>
      <view class="status-value status-{{jwxtStatusTone}}">{{jwxtStatusText}}</view>
      <view class="status-desc">用于查询课表和成绩</view>
    </view>
  </view>

  <view class="card bind-card">
    <view class="card-title">绑定教务账号</view>
    <view class="hint">教务账号仅用于查询课表和成绩。若教务系统要求验证码，请先到官网登录完成验证后再重试。</view>
    <input class="input" placeholder="请输入学号" value="{{studentId}}" bindinput="onStudentIdInput" />
    <input class="input" placeholder="请输入教务密码" password value="{{password}}" bindinput="onPasswordInput" />

    <view wx:if="{{captchaExpanded}}" class="captcha-panel">
      <view wx:if="{{!captchaRelayEnabled}}" class="captcha-fallback">
        <view class="captcha-title">教务系统需要验证码验证</view>
        <view class="captcha-desc">请先到官网登录教务系统完成验证后，再回到小程序重试绑定。</view>
        <button class="captcha-btn" loading="{{binding}}" disabled="{{binding}}" bindtap="retryAfterOfficialCaptcha">我已完成验证，重试</button>
      </view>
      <block wx:else>
        <image wx:if="{{captchaImage}}" class="captcha-image" src="{{captchaImage}}" mode="aspectFit" bindtap="getCaptcha" />
        <input class="input captcha-input" placeholder="请输入验证码" value="{{captchaCode}}" bindinput="onCaptchaInput" />
        <button class="captcha-btn" loading="{{captchaLoading}}" disabled="{{captchaLoading}}" bindtap="getCaptcha">{{captchaImage ? '重新获取' : '获取验证码'}}</button>
      </block>
    </view>

    <button class="bind-btn" loading="{{binding || captchaBinding}}" disabled="{{binding || captchaBinding}}" bindtap="bindAccount">{{captchaExpanded && captchaRelayEnabled ? '验证码绑定' : '绑定教务账号'}}</button>
    <button class="unbind-btn" loading="{{unbinding}}" disabled="{{unbinding}}" bindtap="unbindAccount">解除绑定</button>
  </view>

  <view class="debug-toggle" bindtap="toggleDebug">关于与调试 {{debugExpanded ? '⌃' : '⌄'}}</view>
  <view wx:if="{{debugExpanded}}" class="card debug-card">
    <view class="row">
      <text class="label">apiBase</text>
      <text class="value">{{apiAddr}}</text>
    </view>
    <view class="row">
      <text class="label">clientVersion</text>
      <text class="value">{{clientVersion}}</text>
    </view>
    <view class="row">
      <text class="label">登录状态</text>
      <text class="value">{{loginStatus}}</text>
    </view>
    <view wx:if="{{connectionError}}" class="diagnostic">
      <view class="diagnostic-title">连接诊断</view>
      <view class="diagnostic-text">{{connectionError}}</view>
    </view>
    <view class="debug-desc">后端 API 需保持在线；绑定后可查询课表和成绩。</view>
  </view>
</view>
