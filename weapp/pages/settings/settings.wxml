<view class="container">
  <view class="status-card">
    <view class="status-label">教务绑定</view>
    <view class="status-value status-{{statusTone}}">{{statusTitle}}</view>
    <view class="status-desc">{{statusDesc}}</view>
    <view wx:if="{{lastSyncText}}" class="status-meta">最近同步时间：{{lastSyncText}}</view>
    <view wx:if="{{syncMetaText}}" class="status-meta">{{syncMetaText}}</view>
  </view>

  <view wx:if="{{!hasBoundJwxt || status === 'SYNC_FAILED'}}" class="card bind-card">
    <view class="card-title">{{status === 'SYNC_FAILED' ? '重新绑定教务账号' : '绑定教务账号'}}</view>
    <view class="hint">教务账号仅用于课表、成绩和教务状态同步。绑定后系统会自动同步，无需重复登录教务系统。</view>
    <input class="input" placeholder="请输入学号" value="{{studentId}}" bindinput="onStudentIdInput" />
    <input class="input" placeholder="请输入教务密码" password value="{{password}}" bindinput="onPasswordInput" />
    <view class="privacy-consent">
      <checkbox-group bindchange="onPrivacyChange">
        <label class="privacy-label"><checkbox value="accepted" checked="{{privacyAccepted}}" color="#1677ff" />我已阅读并同意</label>
      </checkbox-group>
      <text class="privacy-link" bindtap="openPrivacy">《用户隐私保护指引》</text>
    </view>
    <button class="bind-btn" loading="{{binding}}" disabled="{{binding || !privacyAccepted}}" bindtap="bindAccount">绑定教务账号</button>
    <view wx:if="{{showRebindActions}}" class="action-row">
      <button class="light-btn" bindtap="retryLater">稍后再试</button>
    </view>
  </view>

  <view wx:if="{{hasBoundJwxt && status !== 'SYNC_FAILED'}}" class="card bound-card">
    <view class="card-title">已绑定教务账号</view>
    <view class="hint">系统会自动同步课表和成绩，无需重复登录。若更换教务密码，可先解除绑定后重新绑定。</view>
    <button class="unbind-btn" loading="{{unbinding}}" disabled="{{unbinding}}" bindtap="unbindAccount">解除绑定</button>
  </view>

  <view wx:if="{{hasBoundJwxt && status === 'SYNC_FAILED'}}" class="card bound-card">
    <view class="card-title">同步处理</view>
    <view class="hint">如已确认密码变更或学校验证要求，请重新绑定教务账号；也可以稍后再试。</view>
    <button class="unbind-btn" loading="{{unbinding}}" disabled="{{unbinding}}" bindtap="unbindAccount">解除绑定</button>
  </view>

</view>
