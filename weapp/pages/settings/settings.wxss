.container {
  min-height: 100vh;
  padding: 20rpx;
  background: #f5f6fa;
}

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(30, 42, 62, 0.06);
}

.card-title {
  margin-bottom: 22rpx;
  color: #1f2d3d;
  font-size: 32rpx;
  font-weight: 600;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f1f5;
}

.label {
  flex-shrink: 0;
  color: #666;
  font-size: 26rpx;
}

.value {
  color: #333;
  font-size: 26rpx;
  text-align: right;
  word-break: break-all;
}

.hint {
  margin-bottom: 18rpx;
  color: #888;
  font-size: 24rpx;
  line-height: 1.6;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  margin-bottom: 18rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e4e7ed;
  border-radius: 12rpx;
  background: #fafafa;
  color: #333;
  font-size: 28rpx;
}

.bind-btn {
  margin-top: 8rpx;
  border-radius: 12rpx;
  background: #1677ff;
  color: #ffffff;
}

.desc {
  color: #666;
  font-size: 26rpx;
  line-height: 1.8;
}
