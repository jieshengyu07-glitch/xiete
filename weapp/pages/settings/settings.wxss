.hint {
  margin-bottom: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f6f9ff;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.diagnostic {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #fed7aa;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-all;
}

.diagnostic-title {
  margin-bottom: 6rpx;
  color: #7c2d12;
  font-weight: 600;
}

.diagnostic-text {
  color: #9a3412;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  margin-bottom: 18rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9e7ff;
  border-radius: 16rpx;
  background: #f8fbff;
  color: #25324a;
  font-size: 28rpx;
}

.bind-btn {
  margin-top: 10rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1677ff 0%, #2f8cff 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(22, 119, 255, 0.2);
}

.captcha-btn {
  margin-top: 0;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-weight: 600;
}

.captcha-panel {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f6f9ff;
}

.captcha-image {
  width: 260rpx;
  height: 92rpx;
  margin-bottom: 18rpx;
  border-radius: 10rpx;
  background: #ffffff;
}

.captcha-link {
  padding: 22rpx 0 8rpx;
  color: #1677ff;
  font-size: 25rpx;
  text-align: center;
}

.unbind-btn {
  margin-top: 18rpx;
  border: 1rpx solid #ffd6d6;
  border-radius: 16rpx;
  background: #fff5f5;
  color: #d92d20;
}

.desc {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.9;
}
