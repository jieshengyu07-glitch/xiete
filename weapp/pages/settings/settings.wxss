.status-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(38, 84, 153, 0.08);
}

.status-label {
  color: #667085;
  font-size: 24rpx;
}

.status-value {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-ok {
  color: #1677ff;
}

.status-warn {
  color: #d98000;
}

.status-err {
  color: #d92d20;
}

.status-muted {
  color: #25324a;
}

.status-desc {
  margin-top: 10rpx;
  color: #98a2b3;
  font-size: 24rpx;
}

.status-meta {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
}

.bind-card {
  padding-bottom: 24rpx;
}

.bound-card {
  padding-bottom: 24rpx;
}

.hint {
  margin-bottom: 22rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  margin-bottom: 18rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9e7ff;
  border-radius: 16rpx;
  background: #f8fbff;
  color: #25324a;
  font-size: 28rpx;
}

.bind-btn {
  margin-top: 8rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1677ff 0%, #2f8cff 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(22, 119, 255, 0.2);
}

.privacy-consent {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 4rpx 0 18rpx;
  color: #667085;
  font-size: 24rpx;
}

.privacy-label {
  display: flex;
  align-items: center;
}

.privacy-label checkbox {
  transform: scale(0.78);
}

.privacy-link {
  color: #1677ff;
  font-weight: 700;
}

.action-row {
  margin-top: 18rpx;
}

.light-btn {
  height: 76rpx;
  margin: 0;
  border-radius: 16rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.captcha-panel {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f6f9ff;
}

.captcha-title {
  color: #25324a;
  font-size: 26rpx;
  font-weight: 700;
}

.captcha-desc {
  margin: 10rpx 0 18rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.captcha-image {
  width: 260rpx;
  height: 92rpx;
  margin-bottom: 18rpx;
  border-radius: 10rpx;
  background: #ffffff;
}

.captcha-input {
  background: #ffffff;
}

.captcha-btn {
  height: 72rpx;
  margin: 0;
  border-radius: 16rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 72rpx;
}

.unbind-btn {
  margin-top: 18rpx;
  border: 1rpx solid #ffd6d6;
  border-radius: 16rpx;
  background: #fffafa;
  color: #d92d20;
}
