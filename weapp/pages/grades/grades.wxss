.grades-page {
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.auth-card {
  margin-top: 72rpx;
  padding: 56rpx 36rpx 40rpx;
  text-align: center;
}

.auth-icon {
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1677ff 0%, #44a3ff 100%);
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 104rpx;
}

.auth-title {
  color: #152338;
  font-size: 34rpx;
  font-weight: 850;
}

.auth-desc {
  margin: 18rpx auto 32rpx;
  color: #77849a;
  font-size: 25rpx;
  line-height: 1.65;
}

.auth-button {
  height: 84rpx;
  margin: 0;
  border-radius: 18rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 84rpx;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 32rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(38, 84, 153, 0.08);
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-title {
  color: #152338;
  font-size: 38rpx;
  font-weight: 850;
}

.summary-meta {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.refresh-btn {
  flex-shrink: 0;
  width: 180rpx;
  height: 72rpx;
  margin: 0;
  border-radius: 16rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 750;
  line-height: 72rpx;
}

.notice-card {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #cfe2ff;
  border-radius: 16rpx;
  background: #f0f6ff;
  color: #2f5f9f;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-title {
  color: #152338;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.45;
}

.term-tabs {
  margin: 0 -24rpx 22rpx;
  white-space: nowrap;
}

.term-tabs-inner {
  display: flex;
  padding: 0 24rpx;
}

.term-tab {
  flex-shrink: 0;
  max-width: 340rpx;
  margin-right: 16rpx;
  padding: 17rpx 26rpx;
  border: 1rpx solid #e6eefb;
  border-radius: 999rpx;
  background: #ffffff;
  color: #506078;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow: 0 6rpx 18rpx rgba(38, 84, 153, 0.06);
}

.term-tab.active {
  border-color: #1677ff;
  background: #1677ff;
  color: #ffffff;
  font-weight: 700;
}

.term-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 4rpx 18rpx;
}

.term-title {
  flex: 1;
  min-width: 0;
  color: #152338;
  font-size: 30rpx;
  font-weight: 750;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.term-count {
  flex-shrink: 0;
  color: #8a94a6;
  font-size: 24rpx;
}

.grade-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.08);
}

.course-name {
  margin-bottom: 22rpx;
  color: #152338;
  font-size: 31rpx;
  font-weight: 750;
  line-height: 1.45;
}

.grade-info {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 18rpx;
}

.score-block,
.info-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
}

.score-block {
  flex: 1.1;
  background: #eef6ff;
}

.info-label {
  display: block;
  margin-bottom: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.score {
  color: #1677ff;
  font-size: 38rpx;
  font-weight: 850;
  line-height: 1.2;
}

.info-value {
  color: #25324a;
  font-size: 26rpx;
  font-weight: 700;
  word-break: break-all;
}

.term-line {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eef2f8;
  color: #8a94a6;
  font-size: 24rpx;
}
