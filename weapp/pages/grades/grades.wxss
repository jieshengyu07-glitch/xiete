.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 32rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(38, 84, 153, 0.08);
}

.summary-title {
  color: #152338;
  font-size: 38rpx;
  font-weight: 800;
}

.summary-meta {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.summary-badge {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 26rpx;
  font-weight: 700;
}

.term-tabs {
  margin: 0 -24rpx 22rpx;
  white-space: nowrap;
}

.term-tabs-inner {
  display: flex;
  padding: 0 24rpx;
}

.term-tab {
  flex-shrink: 0;
  max-width: 340rpx;
  margin-right: 16rpx;
  padding: 17rpx 26rpx;
  border: 1rpx solid #e6eefb;
  border-radius: 999rpx;
  background: #ffffff;
  color: #506078;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow: 0 6rpx 18rpx rgba(38, 84, 153, 0.06);
}

.term-tab.active {
  border-color: #1677ff;
  background: #1677ff;
  color: #ffffff;
  font-weight: 700;
}

.term-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 4rpx 18rpx;
}

.term-title {
  color: #152338;
  font-size: 30rpx;
  font-weight: 750;
}

.term-count {
  color: #8a94a6;
  font-size: 24rpx;
}

.grade-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.08);
}

.course-name {
  margin-bottom: 22rpx;
  color: #152338;
  font-size: 31rpx;
  font-weight: 750;
  line-height: 1.45;
}

.grade-info {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 18rpx;
}

.score-block,
.info-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
}

.score-block {
  flex: 1.15;
  background: #eef6ff;
}

.info-label {
  display: block;
  margin-bottom: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.score {
  color: #1677ff;
  font-size: 38rpx;
  font-weight: 850;
  line-height: 1.2;
}

.info-value {
  color: #25324a;
  font-size: 26rpx;
  font-weight: 700;
}
