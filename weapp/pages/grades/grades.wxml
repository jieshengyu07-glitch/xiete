<view class="container">
  <view class="card" wx:if="{{loading}}"><view class="loading">加载中...</view></view>
  <view class="card" wx:elif="{{error}}">
    <view class="card-title">⚠️ 连接异常</view>
    <view class="row"><text class="label">{{error}}</text></view>
  </view>
  <block wx:else>
    <view class="summary-card">
      <view class="summary-title">成绩列表</view>
      <view class="summary-meta">{{count}} 条成绩 · {{groupedGrades.length}} 个学期</view>
    </view>

    <view wx:if="{{grades.length===0}}" class="empty">暂无成绩数据</view>

    <block wx:else>
      <scroll-view scroll-x class="term-tabs" show-scrollbar="{{false}}">
        <view class="term-tabs-inner">
          <view
            wx:for="{{groupedGrades}}"
            wx:for-item="group"
            wx:for-index="index"
            wx:key="key"
            class="term-tab {{activeTermIndex===index?'active':''}}"
            data-index="{{index}}"
            bindtap="selectTerm"
          >
            {{group.shortName}}
          </view>
        </view>
      </scroll-view>

      <view class="term-header">
        <view class="term-title">{{currentGroup.termName}}</view>
        <view class="term-count">{{currentGrades.length}} 门课程</view>
      </view>

      <view wx:for="{{currentGrades}}" wx:for-item="grade" wx:key="kcmc" class="grade-card">
        <view class="course-name">{{grade.kcmc || "未知课程"}}</view>
        <view class="grade-info">
          <view class="info-item">
            <text class="info-label">成绩</text>
            <text class="score">{{grade.cj || "-"}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">学分</text>
            <text class="info-value">{{grade.xf || "-"}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">学期</text>
            <text class="info-value">{{grade.xnm || "-"}}-{{grade.xqm || "-"}}</text>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>
