<view class="container grades-page">
  <view wx:if="{{loading}}" class="card">
    <view class="loading">加载中...</view>
  </view>

  <view wx:elif="{{authRequired}}" class="card auth-card">
    <view class="auth-icon">绩</view>
    <view class="auth-title">登录后查看成绩</view>
    <view class="auth-desc">本服务仅面向持有学校有效统一身份认证账号的校内用户。</view>
    <button class="auth-button" bindtap="goLogin">前往登录</button>
  </view>

  <block wx:else>
    <view class="summary-card">
      <view class="summary-main">
        <view class="summary-title">成绩查询</view>
        <view class="summary-meta">{{count}} 条成绩 · {{groupedGrades.length}} 个学期</view>
      </view>
      <button class="refresh-btn" loading="{{refreshing}}" disabled="{{refreshing}}" bindtap="refreshGrades">刷新成绩</button>
    </view>

    <view wx:if="{{notice && !syncing}}" class="notice-card">{{notice}}</view>

    <view wx:if="{{syncing}}" class="notice-card">{{notice || "正在同步成绩..."}}</view>

    <view wx:if="{{!syncing && grades.length===0}}" class="card empty-card">
      <view class="empty-title">暂无成绩数据，请先完成登录或刷新成绩</view>
      <view class="tips">成绩由后端统一处理后返回，前端不会解析学工系统 HTML。</view>
      <button class="btn" loading="{{refreshing}}" disabled="{{refreshing}}" bindtap="refreshGrades">刷新成绩</button>
    </view>

    <block wx:if="{{grades.length>0}}">
      <view wx:if="{{error}}" class="card">
        <view class="tips">{{error}}</view>
      </view>

      <scroll-view scroll-x class="term-tabs" show-scrollbar="{{false}}">
        <view class="term-tabs-inner">
          <view
            wx:for="{{groupedGrades}}"
            wx:for-item="group"
            wx:for-index="index"
            wx:key="key"
            class="term-tab {{activeTermIndex===index?'active':''}}"
            data-index="{{index}}"
            bindtap="selectTerm"
          >
            {{group.shortName}}
          </view>
        </view>
      </scroll-view>

      <view class="term-header">
        <view class="term-title">{{currentGroup.termName}}</view>
        <view class="term-count">{{currentGrades.length}} 门课程</view>
      </view>

      <view wx:for="{{currentGrades}}" wx:for-item="grade" wx:key="id" class="grade-card">
        <view class="course-name">{{grade.courseName}}</view>
        <view class="grade-info">
          <view class="score-block">
            <text class="info-label">成绩</text>
            <text class="score">{{grade.score}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">学分</text>
            <text class="info-value">{{grade.credit}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">类型</text>
            <text class="info-value">{{grade.courseType}}</text>
          </view>
        </view>
        <view class="term-line">学期：{{grade.termName}} · 来源：{{grade.sourceText}}</view>
      </view>
    </block>
  </block>
</view>
