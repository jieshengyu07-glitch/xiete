.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1677ff 0%, #44a3ff 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(22, 119, 255, 0.24);
}

.hero-eyebrow {
  opacity: 0.86;
  font-size: 24rpx;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  opacity: 0.86;
  font-size: 24rpx;
}

.hero-count {
  flex-shrink: 0;
  min-width: 150rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.18);
  text-align: center;
}

.hero-number {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.9;
}

.status-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.status-cell {
  box-sizing: border-box;
  width: calc((100% - 18rpx) / 2);
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
}

.status-cell.wide {
  width: 100%;
}

.status-label {
  color: #8a94a6;
  font-size: 23rpx;
}

.status-value {
  margin-top: 10rpx;
  color: #22304a;
  font-size: 28rpx;
  font-weight: 700;
}

.status-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  margin-right: 10rpx;
  border-radius: 50%;
}

.status-ok {
  background: #20c997;
}

.status-err {
  background: #ff6b6b;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin: -4rpx 0 24rpx;
}

.action-btn {
  flex: 1;
  height: 82rpx;
  margin: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 82rpx;
}

.primary-action {
  background: linear-gradient(135deg, #1677ff 0%, #2f8cff 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(22, 119, 255, 0.2);
}

.secondary-action {
  background: #eaf2ff;
  color: #1677ff;
  box-shadow: none;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.no-margin {
  margin-bottom: 0;
}

.pill {
  min-width: 48rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
}

.pill-ok {
  background: #e8fff6;
  color: #12a474;
}

.pill-warn {
  background: #fff7e8;
  color: #d98000;
}

.warning {
  margin-bottom: 18rpx;
  color: #d98000;
  font-size: 28rpx;
  font-weight: 700;
}

.eval-item,
.change-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f8;
}

.eval-item {
  display: block;
}

.eval-course {
  color: #25324a;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.5;
}

.eval-term,
.change-time {
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.change-tag {
  flex-shrink: 0;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 44rpx;
}

.tag-added {
  background: #1677ff;
}

.tag-changed {
  background: #f59f00;
}

.change-main {
  flex: 1;
  min-width: 0;
}

.change-text {
  color: #25324a;
  font-size: 27rpx;
  line-height: 1.5;
}
