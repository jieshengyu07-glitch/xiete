<view class="container">
  <view class="card" wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="card-title">连接异常</view>
    <view class="row">
      <text class="label">{{error}}</text>
    </view>
    <button class="btn" bindtap="refresh">重新连接</button>
    <view class="tips">请确认后端服务已启动：npm start</view>
  </view>

  <block wx:else>
    <view class="card">
      <view class="card-title">服务状态</view>
      <view class="row">
        <text class="label">服务状态</text>
        <text class="value">
          <text class="status-dot {{status.status==='running'?'status-ok':'status-err'}}"></text>{{status.status}}
        </text>
      </view>
      <view class="row">
        <text class="label">Cookie 状态</text>
        <text class="value">
          <text class="status-dot {{status.cookieValid?'status-ok':'status-err'}}"></text>{{status.cookieValid?'有效':'已过期'}}
        </text>
      </view>
      <view class="row">
        <text class="label">已存成绩</text>
        <text class="value">{{status.totalGrades}} 条</text>
      </view>
      <view class="row">
        <text class="label">上次检查</text>
        <text class="value">{{status.lastCheckAtFormatted||'尚未检查'}}</text>
      </view>
    </view>

    <view class="card">
      <view class="card-title">未评价课程提醒</view>
      <view wx:if="{{status.unevaluatedCount > 0}}">
        <view class="warning">检测到未完成教学评价</view>
        <view wx:for="{{status.unevaluatedCourses}}" wx:key="kcmc" class="eval-item">
          <view class="eval-course">{{item.kcmc}}</view>
          <view class="eval-term">{{item.termName}}</view>
        </view>
        <view class="tips">请前往教务系统完成教学评价</view>
      </view>
      <view wx:else class="empty">暂无未评价课程</view>
    </view>

    <view class="card">
      <view class="card-title">最近成绩变化</view>
      <view wx:if="{{gradeChanges.length === 0}}" class="empty">暂无新成绩变化</view>
      <view wx:for="{{gradeChanges}}" wx:key="createdAt" class="change-item">
        <view class="change-tag {{item.type === 'changed' ? 'tag-changed' : 'tag-added'}}">{{item.displayType}}</view>
        <view class="change-main">
          <view class="change-text">{{item.displayText}}</view>
          <view class="change-time">{{item.createdAt}}</view>
        </view>
      </view>
    </view>

    <button class="btn" bindtap="doCheck">立即检查成绩</button>
    <button class="btn secondary" bindtap="refresh">刷新状态</button>
  </block>
</view>
