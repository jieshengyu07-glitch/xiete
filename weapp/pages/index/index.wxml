<view class="container">
  <view class="card" wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="card-title">{{errorTitle || '连接异常'}}</view>
    <view class="row">
      <text class="label">{{error}}</text>
    </view>
    <button class="btn" bindtap="refresh">重新连接</button>
    <view class="tips">请检查网络连接后重试；服务恢复后页面会正常加载。</view>
  </view>

  <block wx:else>
    <view class="hero-card">
      <view>
        <view class="hero-eyebrow">校园助手</view>
        <view class="hero-title">成绩监测中心</view>
        <view class="hero-subtitle">自动检查成绩、评教状态与最新变化</view>
      </view>
      <view class="hero-count">
        <view class="hero-number">{{status.totalGrades}}</view>
        <view class="hero-unit">条成绩</view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">服务状态</view>
      <view wx:if="{{statusMessage}}" class="tips">{{statusMessage}}</view>
      <view class="status-grid">
        <view class="status-cell">
          <view class="status-label">服务</view>
          <view class="status-value">
            <text class="status-dot {{status.status==='running'?'status-ok':'status-err'}}"></text>{{status.status==='running'?'正常':'暂不可用'}}
          </view>
        </view>
        <view class="status-cell">
          <view class="status-label">校园账号</view>
          <view class="status-value">
            <text class="status-dot {{status.bound?'status-ok':'status-err'}}"></text>{{status.bound?(status.campusLoginStatus==='recovering'?'恢复中':'已绑定'):'未绑定'}}
          </view>
        </view>
        <view class="status-cell wide">
          <view class="status-label">上次检查</view>
          <view class="status-value">{{status.lastCheckAtFormatted||'尚未检查'}}</view>
        </view>
      </view>
    </view>

    <view class="action-row">
      <button class="action-btn primary-action" bindtap="doCheck">立即检查成绩</button>
      <button class="action-btn secondary-action" bindtap="refresh">刷新状态</button>
    </view>

    <view class="card">
      <view class="section-head">
        <view class="card-title no-margin">未评价课程提醒</view>
        <view class="pill {{status.unevaluatedCount > 0 ? 'pill-warn' : 'pill-ok'}}">{{status.unevaluatedCount || 0}}</view>
      </view>
      <view wx:if="{{status.unevaluatedCount > 0}}">
        <view class="warning">检测到未完成教学评价</view>
        <view wx:for="{{status.unevaluatedCourses}}" wx:key="kcmc" class="eval-item">
          <view class="eval-course">{{item.kcmc}}</view>
          <view class="eval-term">{{item.termName}}</view>
        </view>
        <view class="tips">请前往教务系统完成教学评价</view>
      </view>
      <view wx:else class="empty">暂无未评价课程</view>
    </view>

    <view class="card">
      <view class="card-title">最近成绩变化</view>
      <view wx:if="{{gradeChanges.length === 0}}" class="empty">暂无新成绩变化</view>
      <view wx:for="{{gradeChanges}}" wx:key="createdAt" class="change-item">
        <view class="change-tag {{item.type === 'changed' ? 'tag-changed' : 'tag-added'}}">{{item.displayType}}</view>
        <view class="change-main">
          <view class="change-text">{{item.displayText}}</view>
          <view class="change-time">{{item.createdAt}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
