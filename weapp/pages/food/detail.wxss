.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f7f9fc;
}

.hero-card,
.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.hero-card {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #ff9f1c 0%, #ffbf69 100%);
  color: #ffffff;
}

.food-name {
  font-size: 40rpx;
  font-weight: 850;
}

.food-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.score {
  flex-shrink: 0;
  font-size: 44rpx;
  font-weight: 850;
}

.score text {
  margin-left: 3rpx;
  font-size: 22rpx;
}

.card-title {
  margin-bottom: 20rpx;
  color: #152338;
  font-size: 30rpx;
  font-weight: 800;
}

.dim-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dim-item {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
}

.dim-label {
  color: #98a2b3;
  font-size: 23rpx;
}

.dim-value {
  margin-top: 8rpx;
  color: #ff8a00;
  font-size: 34rpx;
  font-weight: 850;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #d98000;
  font-size: 23rpx;
  font-weight: 700;
}

.hot-comment,
.comment {
  color: #4b5870;
  font-size: 25rpx;
  line-height: 1.6;
}

.comment {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f8;
}

.comment:last-child {
  border-bottom: none;
}

.easter-egg {
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #98a2b3;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.egg-title {
  color: #667085;
  font-size: 24rpx;
  font-weight: 750;
}

.egg-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.55;
}
