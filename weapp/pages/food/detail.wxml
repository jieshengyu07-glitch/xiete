<view class="page">
  <view class="hero-card">
    <view>
      <view class="food-name">{{food.name}}</view>
      <view class="food-meta">{{food.canteen}} · {{food.window}}</view>
    </view>
    <view class="score">{{food.score}}<text>分</text></view>
  </view>

  <view class="card">
    <view class="card-title">评分维度</view>
    <view class="dim-grid">
      <view wx:for="{{food.dimensions}}" wx:key="label" class="dim-item">
        <view class="dim-label">{{item.label}}</view>
        <view class="dim-value">{{item.value}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">标签</view>
    <view class="tag-row">
      <text wx:for="{{food.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">热门评价</view>
    <view class="hot-comment">“{{food.hotComment}}”</view>
  </view>

  <view class="card">
    <view class="card-title">最新评价</view>
    <block wx:if="{{food.comments.length}}">
      <view wx:for="{{food.comments}}" wx:key="*this" class="comment">“{{item}}”</view>
    </block>
    <empty-state
      wx:else
      title="暂无美食评价"
      subtitle="干饭情报等待补充。"
      imageType="food-empty"
    />
  </view>

  <view class="easter-egg">
    <view class="egg-title">小提示</view>
    <view class="egg-text">第一口情报很珍贵，但也要记得客观一点。</view>
  </view>
</view>
