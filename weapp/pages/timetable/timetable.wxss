.timetable-page {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.auth-card {
  margin-top: 72rpx;
  padding: 56rpx 36rpx 40rpx;
  text-align: center;
}

.auth-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1677ff 0%, #44a3ff 100%);
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 850;
  box-shadow: 0 14rpx 30rpx rgba(22, 119, 255, 0.2);
}

.auth-title {
  color: #152338;
  font-size: 34rpx;
  font-weight: 850;
}

.auth-desc {
  max-width: 540rpx;
  margin: 18rpx auto 32rpx;
  color: #77849a;
  font-size: 25rpx;
  line-height: 1.65;
}

.auth-button {
  width: 100%;
  height: 84rpx;
  margin: 0;
  border-radius: 18rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 84rpx;
}

.timetable-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #1677ff 0%, #44a3ff 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(22, 119, 255, 0.22);
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.25;
}

.date-line {
  margin-top: 8rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.3;
}

.week-line {
  margin-top: 6rpx;
  opacity: 0.9;
  font-size: 22rpx;
}

.refresh-btn {
  flex-shrink: 0;
  width: 156rpx;
  height: 64rpx;
  margin: 0;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 23rpx;
  line-height: 64rpx;
}

.notice-card {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #cfe2ff;
  border-radius: 16rpx;
  background: #f0f6ff;
  color: #2f5f9f;
  font-size: 25rpx;
  line-height: 1.5;
}

.view-switch {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #eaf2ff;
}

.switch-item {
  flex: 1;
  padding: 14rpx 0;
  border-radius: 12rpx;
  color: #607089;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
}

.switch-item.active {
  background: #ffffff;
  color: #1677ff;
  box-shadow: 0 6rpx 18rpx rgba(22, 119, 255, 0.12);
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.week-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.week-day-card {
  padding: 22rpx;
  border: 1rpx solid #e8eef8;
  border-radius: 20rpx;
  background: #ffffff;
}

.week-day-title {
  margin-bottom: 12rpx;
  color: #152338;
  font-size: 28rpx;
  font-weight: 800;
}

.week-section-list {
  overflow: hidden;
  border: 1rpx solid #e8eef8;
  border-radius: 14rpx;
}

.week-section {
  display: flex;
  align-items: stretch;
  min-height: 72rpx;
  background: #f8fbff;
}

.week-section + .week-section {
  border-top: 1rpx solid #e8eef8;
}

.week-section-label {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  width: 138rpx;
  padding: 14rpx 16rpx;
  border-right: 1rpx solid #e8eef8;
  color: #607089;
  font-size: 23rpx;
  font-weight: 700;
}

.week-section-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  padding: 12rpx 18rpx;
}

.week-course-name {
  color: #17233c;
  font-size: 25rpx;
  font-weight: 750;
  line-height: 1.45;
}

.week-course-name + .week-course-name {
  margin-top: 6rpx;
}

.week-no-class {
  color: #98a2b3;
  font-size: 24rpx;
}

.lesson-card {
  box-sizing: border-box;
  min-height: 146rpx;
  padding: 24rpx;
  border: 1rpx solid #e8eef8;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.lesson-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.lesson-title {
  color: #152338;
  font-size: 27rpx;
  font-weight: 800;
}

.lesson-time {
  flex-shrink: 0;
  margin-top: 0;
  color: #8a94a6;
  font-size: 23rpx;
}

.no-class {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  padding: 10rpx 0;
  border-radius: 16rpx;
  background: #f6f9ff;
  color: #98a2b3;
  font-size: 26rpx;
  text-align: center;
}

.course-block {
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f4f8ff;
}

.course-block + .course-block {
  margin-top: 16rpx;
}

.course-name {
  margin-bottom: 10rpx;
  color: #17233c;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.45;
}

.course-row {
  display: flex;
  gap: 16rpx;
  color: #506078;
  font-size: 24rpx;
  line-height: 1.55;
}

.course-row + .course-row {
  margin-top: 6rpx;
}

.course-label {
  flex-shrink: 0;
  width: 60rpx;
  color: #1677ff;
  font-weight: 750;
}

.error-card {
  border-color: #ffd6d6;
  background: #fff5f5;
}

.error-text {
  color: #d92d20;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}
