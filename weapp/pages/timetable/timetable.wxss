.timetable-page {
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.timetable-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1677ff 0%, #44a3ff 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(22, 119, 255, 0.22);
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 850;
  line-height: 1.25;
}

.date-line {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.week-line {
  margin-top: 8rpx;
  opacity: 0.9;
  font-size: 24rpx;
}

.refresh-btn {
  flex-shrink: 0;
  width: 180rpx;
  height: 72rpx;
  margin: 0;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 72rpx;
}

.notice-card {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #cfe2ff;
  border-radius: 16rpx;
  background: #f0f6ff;
  color: #2f5f9f;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-card {
  text-align: left;
}

.empty-title {
  color: #152338;
  font-size: 32rpx;
  font-weight: 800;
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.lesson-card {
  padding: 28rpx;
  border: 1rpx solid #e8eef8;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.lesson-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.lesson-title {
  color: #152338;
  font-size: 30rpx;
  font-weight: 800;
}

.lesson-time {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
}

.no-class {
  padding: 26rpx 0;
  border-radius: 16rpx;
  background: #f6f9ff;
  color: #98a2b3;
  font-size: 27rpx;
  text-align: center;
}

.course-block {
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f4f8ff;
}

.course-block + .course-block {
  margin-top: 16rpx;
}

.course-name {
  margin-bottom: 14rpx;
  color: #17233c;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.45;
}

.course-row {
  display: flex;
  gap: 16rpx;
  color: #506078;
  font-size: 24rpx;
  line-height: 1.55;
}

.course-row + .course-row {
  margin-top: 6rpx;
}

.course-label {
  flex-shrink: 0;
  width: 60rpx;
  color: #1677ff;
  font-weight: 750;
}

.error-card {
  border-color: #ffd6d6;
  background: #fff5f5;
}

.error-text {
  color: #d92d20;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}
