<view class="page">
  <view class="card">
    <view class="title">配置学工成绩渠道</view>
    <view class="desc">打开学工系统的学习成绩查看页面后，粘贴当前完整 URL 和 xg.tyust.edu.cn 的 Cookie。</view>
  </view>

  <view class="form-card">
    <view class="field">
      <view class="label">学工成绩页面 URL</view>
      <textarea
        class="textarea url-input"
        value="{{xgScoreUrl}}"
        placeholder="https://xg.tyust.edu.cn/apps/App_StudentJudge/(S(...))/StuStudentScore.aspx"
        maxlength="-1"
        bindinput="onUrlInput"
      />
      <view class="hint">必须包含 xg.tyust.edu.cn，最好包含 StuStudentScore.aspx。</view>
    </view>

    <view class="field">
      <view class="label">学工系统 Cookie</view>
      <textarea
        class="textarea cookie-input"
        value="{{xgCookies}}"
        placeholder="ASP.NET_SessionId=...; 其他 Cookie=..."
        maxlength="-1"
        bindinput="onCookieInput"
      />
      <view class="hint">保存后不会在页面长期展示完整 Cookie，请勿分享给他人。</view>
    </view>
  </view>

  <button class="save-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="saveSession">保存配置</button>
</view>
