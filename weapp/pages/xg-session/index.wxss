.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #eef6ff 0%, #f7f9fc 320rpx, #f7f9fc 100%);
}

.card,
.form-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(38, 84, 153, 0.07);
}

.title {
  color: #152338;
  font-size: 36rpx;
  font-weight: 850;
}

.desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.6;
}

.field + .field {
  margin-top: 30rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #22304a;
  font-size: 28rpx;
  font-weight: 750;
}

.textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid #dbe7f6;
  border-radius: 18rpx;
  background: #f8fbff;
  color: #22304a;
  font-size: 25rpx;
  line-height: 1.5;
}

.url-input {
  min-height: 150rpx;
}

.cookie-input {
  min-height: 230rpx;
}

.hint {
  margin-top: 12rpx;
  color: #98a2b3;
  font-size: 23rpx;
  line-height: 1.5;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  margin: 0;
  border-radius: 20rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
  box-shadow: 0 12rpx 28rpx rgba(22, 119, 255, 0.22);
}
