NODE_ENV=production
# Legacy single-user credentials are development/script-only. Never define
# JWXT_STUDENT_ID or JWXT_PASSWORD on the production web service.
# JWXT_STUDENT_ID=your_student_id
# JWXT_PASSWORD=your_password
CREDENTIAL_SECRET=change_me_to_a_long_random_secret
# LEGACY_CREDENTIAL_SECRET is only for explicit, read-only recovery of data encrypted with an old key.
# LEGACY_CREDENTIAL_SECRET=
JWT_SECRET=change_me_to_a_long_random_jwt_secret
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
DATA_DIR=/data
# Only for explicitly invoked legacy single-user scripts. Never set this on the production server.
# LEGACY_SINGLE_USER_MODE=1
# Enables authenticated Cookie/session debug routes. Never set for the ordinary production service.
# ADMIN_MODE=true
# ADMIN_MODE must remain unset for the ordinary production service.
# Temporary read-only endpoint: GET /admin/diagnose-data. It also requires
# ADMIN_MODE=true and must be disabled again after diagnosis.
# ADMIN_DIAGNOSTIC_SECRET=set_a_unique_random_value_of_at_least_32_characters
TIMETABLE_TERM_YEAR=2025
TIMETABLE_TERM_SEMESTER=12
SEMESTER_START_DATE=2026-02-24
TEACHING_WEEK_START_DATE=2026-03-09
TEACHING_WEEK_END_DATE=2026-07-12
MAX_TEACHING_WEEKS=18
